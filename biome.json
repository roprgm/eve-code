{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!.claude",
      "!.convex",
      "!.eve",
      "!.output",
      "!.vercel",
      "!.workflow-data",
      "!convex/_generated",
      "!dist"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["@pierre/**"],
                "message": "Pierre imports belong only in the UI primitive and bundler adapters."
              }
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "components/code/diff-renderer.tsx",
        "components/workspace/use-workspace-tree.ts",
        "components/workspace/workspace-browser.tsx",
        "components/workspace/workspace-panel.tsx",
        "lib/pierre-themes.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
